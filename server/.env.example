GEMINI_API_KEY=your_gemini_api_key_here
CLIENT_ORIGIN=http://localhost:5173

# Optional protection: set either PROXY_API_KEY or PROXY_API_USER+PROXY_API_PASS
# to require authentication for /api/gemini requests.
PROXY_API_KEY=your_proxy_api_key_here
#PROXY_API_USER=proxyuser
#PROXY_API_PASS=proxypass

# Put real secret into server/.env (never commit it)
